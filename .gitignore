# Build artifacts (generated by ./configure and make)
*.o
*.a
*.dSYM/
config.mk
config.mk.tmp
config.log

# Built binaries
unasd
tests/api/test_pathjail
tests/api/test_http
tests/api/test_jsonw

# Runtime state (token + port the UI reads) — never authoritative, never committed
# Written into $UNAS_STATE as unas.token / unas.port (see write_state).
*.token
*.port

# Secrets — supplied via the environment or a token file, never committed
.env
*.key
*.pem

# macOS
.DS_Store
